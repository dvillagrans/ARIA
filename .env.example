# ============================================================
# ARIA — Environment Variables Reference
# Copy this file to .env and fill in the values.
# Run `supabase status` after `supabase start` to obtain the
# Supabase keys.
# ============================================================

# ----------------------------------------------------------
# Supabase (local dev — update for staging/prod)
# ----------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<from: supabase status>
SUPABASE_SERVICE_ROLE_KEY=<from: supabase status>

# ----------------------------------------------------------
# LLM / Embeddings (not used in Phase 0 — stubs only)
# ----------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPINFRA_API_KEY=

# ----------------------------------------------------------
# Backend
# ----------------------------------------------------------
ENVIRONMENT=development

# ----------------------------------------------------------
# Frontend (NEXT_PUBLIC_* are exposed to the browser bundle)
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from: supabase status>
NEXT_PUBLIC_API_URL=http://localhost:8000
