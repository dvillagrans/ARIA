  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(aria_http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 80}
            ]
          }
        }
      }
    },
    {
